
import { test, expect } from '@playwright/test';

test('add todo item', async ({ page }) => {
const taskName = 'Pay electricity bill';

await page.goto('https://demo.playwright.dev/todomvc');
await page.getByPlaceholder('What needs to be done?').fill(taskName);

await page.keyboard.press('Enter');
await expect(page.getByText(taskName)).toBeVisible();
});

test('add todo items', async ({ page }) => {
await page.goto('https://demo.playwright.dev/todomvc');
const tasks = ['Pay electricity bill','Review transactions','Approve transfer'];
for (const task of tasks) {
await page.getByPlaceholder('What needs to be done?').fill(task);
await page.keyboard.press('Enter');
}
await expect(page.locator('.todo-list li')).toHaveCount(3);
});

