test('clear completed todos', async ({ page }) => {
  await page.goto('https://demo.playwright.dev/todomvc');

  const tasks = ['task1', 'task2'];

  for (const task of tasks) {
    await page.getByPlaceholder('What needs to be done?').fill(task);
    await page.keyboard.press('Enter');
  }

  await page.locator('.toggle').nth(0).check();
  await page.locator('.toggle').nth(1).check();

  await page.goto('https://demo.playwright.dev/todomvc/#/completed');

  await page.getByRole('button', { name: 'Clear completed' }).click();

  await expect(page.locator('.todo-list li')).toHaveCount(0);
});
